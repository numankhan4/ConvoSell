# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/whatsapp_crm?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# Auth
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="7d"

# App
PORT=3000
NODE_ENV="development"

# Security hardening
# Required for secret encryption/decryption and migration script apply mode.
WHATSAPP_CRM_ENCRYPTION_KEY="replace-with-a-long-random-secret"
# Optional: audit log retention in days (minimum 30, default 365).
AUDIT_LOG_RETENTION_DAYS=365
# Optional: DLP unusual export alert thresholds.
DLP_EXPORT_ALERT_WINDOW_HOURS=24
DLP_EXPORT_ALERT_THRESHOLD=5
DLP_EXPORT_RECORD_THRESHOLD=1000

# WhatsApp (Meta Cloud API)
WHATSAPP_API_URL="https://graph.facebook.com/v18.0"
WHATSAPP_API_TOKEN="your-meta-cloud-api-token"
WHATSAPP_PHONE_NUMBER_ID="your-phone-number-id"
WHATSAPP_WEBHOOK_VERIFY_TOKEN="your-webhook-verify-token"

# Shopify
SHOPIFY_CLIENT_ID="your-shopify-client-id"
SHOPIFY_CLIENT_SECRET="your-shopify-client-secret"
SHOPIFY_WEBHOOK_SECRET="your-shopify-webhook-secret"
SHOPIFY_SCOPES="read_orders,read_customers,read_fulfillments"

# Frontend URL (for CORS)
FRONTEND_URL="http://localhost:3004"

# Email (Resend free tier)
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxx"
RESEND_FROM_EMAIL="ConvoSell <onboarding@yourdomain.com>"

# Observability (optional)
SENTRY_DSN=""
LOG_LEVEL="debug"

# Fraud detection
INTERNAL_WORKER_KEY="change-me-fraud-internal-key"
GEO_API_BASE_URL="https://ipapi.co"
# Optional for paid geo providers
GEO_API_KEY=""
