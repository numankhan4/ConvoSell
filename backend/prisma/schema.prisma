// This is your Prisma schema file
// Multi-tenant WhatsApp CRM schema with outbox pattern for reliability

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// TENANT & AUTH
// ============================================================

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String   // bcrypt hashed
  firstName String?
  lastName  String?
  isActive  Boolean  @default(true)
  
  // Platform-level role (for super admins)
  platformRole String  @default("user") // user, super_admin
  isSuperAdmin Boolean @default(false)
  
  // Profile enhancements
  avatar       String?
  phone        String?
  timezone     String?  @default("Asia/Karachi")
  language     String?  @default("en")
  
  // Security
  emailVerified Boolean  @default(false)
  lastLoginAt   DateTime?
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships WorkspaceMember[]
  auditLogs   AuditLog[]

  @@map("users")
}

model Workspace {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  plan        String   @default("free") // free, starter, pro, business, enterprise
  isActive    Boolean  @default(true)
  maxMembers  Int      @default(3)
  maxContacts Int      @default(1000)
  
  // Subscription & Billing
  subscriptionStatus  String   @default("active") // active, past_due, cancelled, trialing
  subscriptionId      String?  // Stripe/Paddle subscription ID
  stripeCustomerId    String?  // Stripe customer ID
  billingEmail        String?
  trialEndsAt         DateTime?
  subscriptionEndsAt  DateTime?
  
  // Message Quotas (resets monthly)
  templateMessagesLimit   Int      @default(0) // 0 for free, 50 starter, 200 pro, 1000 business, unlimited enterprise
  templateMessagesUsed    Int      @default(0)
  quotaResetAt            DateTime @default(now())

  // Order verification policy (workspace-configurable)
  verificationEnabled             Boolean @default(true)
  verificationScope               String  @default("cod_only") // cod_only, all_orders
  verificationFirstFollowupMinutes Int    @default(120)
  verificationFinalTimeoutMinutes  Int    @default(1440)
  verificationMaxFollowups         Int    @default(2)
  verificationReadAwareEscalation  Boolean @default(true)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members              WorkspaceMember[]
  contacts             Contact[]
  conversations        Conversation[]
  messages             Message[]
  orders               Order[]
  tags                 Tag[]
  automations          Automation[]
  whatsappIntegrations WhatsAppIntegration[]
  shopifyStores        ShopifyStore[]
  outboxEvents         OutboxEvent[]
  auditLogs            AuditLog[]
  whatsappTemplates    WhatsAppMessageTemplate[]
  templateMessages     TemplateMessage[]

  @@index([slug])
  @@index([subscriptionStatus])
  @@index([quotaResetAt])
  @@map("workspaces")
}

model WorkspaceMember {
  id          String   @id @default(cuid())
  workspaceId String
  userId      String
  
  // Enhanced role system: owner, admin, manager, agent, viewer
  role        String   @default("agent")
  
  // Custom permissions override (JSON array of permission strings)
  customPermissions Json?  @default("[]")
  
  // Invitation tracking
  invitedBy   String?  // User ID who invited
  invitedAt   DateTime @default(now())
  joinedAt    DateTime?
  
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([userId])
  @@index([role])
  @@map("workspace_members")
}

model TeamInvitation {
  id          String   @id @default(cuid())
  workspaceId String
  email       String
  role        String   @default("agent") // Role to assign when accepted
  invitedBy   String   // User ID of inviter
  
  // Secure invitation token
  token       String   @unique
  expiresAt   DateTime
  
  // Invitation status
  status      String   @default("pending") // pending, accepted, expired, cancelled
  acceptedAt  DateTime?
  acceptedBy  String?  // User ID who accepted
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([workspaceId, email])
  @@index([token])
  @@index([status])
  @@index([expiresAt])
  @@map("team_invitations")
}

// ============================================================
// WHATSAPP INTEGRATION
// ============================================================

model WhatsAppIntegration {
  id                String   @id @default(cuid())
  workspaceId       String
  phoneNumberId     String   @unique // Meta Cloud API phone number ID
  phoneNumber       String // Display number (e.g., +92300...)
  businessAccountId String
  accessToken       String // Encrypted in production
  refreshToken      String? // For automatic token renewal
  webhookVerifyToken String
  tokenType         String   @default("temporary") // temporary, long-lived, system-user
  tokenExpiresAt    DateTime? // When the access token expires
  isActive          Boolean  @default(true)
  
  // Health monitoring
  lastHealthCheck   DateTime?
  healthStatus      String   @default("unknown") // healthy, warning, error, unknown
  healthError       String? // Last error message if any
  
  // Soft delete (for 30-day grace period)
  deletedAt         DateTime? // When user disconnected
  deletedBy         String?   // User ID who disconnected
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([tokenExpiresAt]) // For finding expiring tokens
  @@map("whatsapp_integrations")
}

// ============================================================
// WHATSAPP MESSAGE TEMPLATES
// ============================================================

model WhatsAppMessageTemplate {
  id                String   @id @default(cuid())
  workspaceId       String
  name              String   // Template name (e.g., "order_confirmation")
  category          String   @default("UTILITY") // UTILITY, MARKETING, AUTHENTICATION
  language          String   @default("en") // en, ur, etc.
  
  // Template structure
  headerType        String?  // TEXT, IMAGE, VIDEO, DOCUMENT
  headerText        String?  // If headerType is TEXT
  headerMediaUrl    String?  // If headerType is media
  bodyText          String   @db.Text // Template body with {{1}} placeholders
  footerText        String?
  buttons           Json?    @default("[]") // Quick reply or CTA buttons
  
  // Variables (for documentation)
  variables         Json?    @default("[]") // [{ name: "customer_name", example: "Ahmed" }]
  
  // Meta approval status
  status            String   @default("PENDING") // PENDING, APPROVED, REJECTED
  metaTemplateId    String?  @unique // Meta's template ID after approval
  rejectionReason   String?
  
  // Stats
  sentCount         Int      @default(0)
  deliveredCount    Int      @default(0)
  readCount         Int      @default(0)
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  workspace        Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  templateMessages TemplateMessage[]

  @@unique([workspaceId, name, language])
  @@index([workspaceId, status])
  @@map("whatsapp_message_templates")
}

model TemplateMessage {
  id              String   @id @default(cuid())
  workspaceId     String
  templateId      String
  
  // Recipient details
  recipientPhone  String // E.164 format
  contactId       String?
  orderId         String?
  
  // Template variables filled
  headerParams    Json?    @default("[]") // Values for header placeholders
  bodyParams      Json     @default("[]") // Values for body placeholders
  buttonParams    Json?    @default("[]") // Values for button placeholders
  
  // WhatsApp delivery
  whatsappMessageId String? @unique
  status           String   @default("pending") // pending, sent, delivered, read, failed
  errorCode        String?
  errorMessage     String?
  
  // Cost tracking (PKR)
  estimatedCost    Float?   // ~5-8 PKR per template
  
  sentAt           DateTime?
  deliveredAt      DateTime?
  readAt           DateTime?
  failedAt         DateTime?
  
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  workspace Workspace              @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  template  WhatsAppMessageTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@index([workspaceId, createdAt])
  @@index([templateId])
  @@index([status])
  @@index([recipientPhone])
  @@map("template_messages")
}

// ============================================================
// SHOPIFY INTEGRATION
// ============================================================

model ShopifyStore {
  id            String   @id @default(cuid())
  workspaceId   String
  shopDomain    String   @unique // e.g., mystore.myshopify.com
  
  // Legacy: Client Credentials (24-hour tokens)
  clientId      String? // From Partners Dashboard
  clientSecret  String? // From Partners Dashboard (encrypted)
  accessToken   String? // Auto-generated token (expires in 24h)
  tokenExpiresAt DateTime? // When to refresh token
  
  // NEW: OAuth 2.0 (permanent tokens until uninstall)
  oauthAccessToken String? @map("oauth_access_token")
  tokenType        String? @default("client-credentials") @map("token_type") // "client-credentials" | "oauth"
  oauthInstalledAt DateTime? @map("oauth_installed_at")
  uninstalledAt    DateTime? @map("uninstalled_at")
  
  scopes        String? // Granted scopes
  isActive      Boolean  @default(true)
  installedAt   DateTime @default(now())
  lastSyncAt    DateTime?
  
  // Multi-store support
  label         String? // "Main Store", "Wholesale", etc.
  
  // Soft delete (for 90-day grace period - longer for business records)
  deletedAt     DateTime? // When user disconnected
  deletedBy     String?   // User ID who disconnected
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  orders    Order[]

  @@index([workspaceId])
  @@index([tokenType])
  @@map("shopify_stores")
}

// ============================================================
// CRM CORE
// ============================================================

model Contact {
  id             String   @id @default(cuid())
  workspaceId    String
  whatsappPhone  String? // Customer's WhatsApp number (E.164 format)
  name           String?
  email          String?
  tags           String[] @default([]) // Tag IDs (for quick filtering)
  customFields   Json?    @default("{}") // Flexible metadata
  totalOrders    Int      @default(0)
  totalSpent     Float    @default(0)
  lastContactAt  DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  workspace     Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  conversations Conversation[]
  orders        Order[]

  @@unique([workspaceId, whatsappPhone])
  @@index([workspaceId, whatsappPhone])
  @@index([workspaceId, lastContactAt])
  @@map("contacts")
}

model Conversation {
  id             String    @id @default(cuid())
  workspaceId    String
  contactId      String
  status         String    @default("open") // open, closed, snoozed
  assignedToId   String?
  lastMessageAt  DateTime?
  lastMessagePreview String?
  unreadCount    Int       @default(0)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  contact   Contact   @relation(fields: [contactId], references: [id], onDelete: Cascade)
  messages  Message[]

  @@index([workspaceId, status, lastMessageAt])
  @@index([contactId])
  @@map("conversations")
}

model Message {
  id              String    @id @default(cuid())
  workspaceId     String
  conversationId  String
  direction       String // inbound, outbound
  type            String    @default("text") // text, image, document, template, button
  content         String?   @db.Text
  mediaUrl        String?
  metadata        Json?     @default("{}") // Button payloads, template vars, etc.
  
  // WhatsApp provider fields
  whatsappMessageId String?  @unique // Meta's message ID (for status tracking)
  status            String?  @default("pending") // pending, sent, delivered, read, failed
  errorCode         String?
  errorMessage      String?

  sentBy      String? // userId if outbound manual
  sentAt      DateTime?
  deliveredAt DateTime?
  readAt      DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  workspace    Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([workspaceId, conversationId, createdAt])
  @@index([whatsappMessageId])
  @@map("messages")
}

model Tag {
  id          String   @id @default(cuid())
  workspaceId String
  name        String
  color       String   @default("#3b82f6") // Hex color
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, name])
  @@index([workspaceId])
  @@map("tags")
}

// ============================================================
// ORDERS
// ============================================================

model Order {
  id                  String    @id @default(cuid())
  workspaceId         String
  contactId           String
  shopifyStoreId      String?
  
  externalOrderId     String // Shopify order ID or custom
  externalOrderNumber String? // Shopify order number (#1001)
  
  status              String    @default("pending") // pending, confirmed, cancelled, completed, fake
  paymentMethod       String    @default("cod") // cod, prepaid
  
  totalAmount         Float
  currency            String    @default("PKR")
  
  items               Json      @default("[]") // Order line items
  shippingAddress     Json?     // Customer address
  
  confirmedAt         DateTime?
  cancelledAt         DateTime?
  deliveredAt         DateTime?
  
  // Automation tracking
  confirmationSentAt  DateTime?
  reminderSentAt      DateTime?
  followupCount       Int       @default(0)
  verificationOutcome String?   // pending_response, confirmed, cancelled, fake_suspected
  verificationFinalizedAt DateTime?
  
  // Enhanced automation fields
  responseTimeMinutes Int? // Time taken to confirm/cancel (minutes)
  feedbackReason      String? // Cancellation reason: wrong_item, changed_mind, price
  shopifyFulfillmentId String? // Track fulfillment in Shopify
  shopifyCancelled    Boolean @default(false) // Track if cancelled in Shopify
  
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  workspace     Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  contact       Contact       @relation(fields: [contactId], references: [id], onDelete: Cascade)
  shopifyStore  ShopifyStore? @relation(fields: [shopifyStoreId], references: [id], onDelete: SetNull)

  @@unique([workspaceId, externalOrderId])
  @@index([workspaceId, status, createdAt])
  @@index([contactId])
  @@map("orders")
}

// ============================================================
// AUTOMATIONS
// ============================================================

model Automation {
  id          String   @id @default(cuid())
  workspaceId String
  name        String
  description String?
  isActive    Boolean  @default(true)
  
  // Simple rule-based automation (MVP)
  trigger     Json     // { type: "order_created", conditions: { paymentMethod: "cod" } }
  actions     Json     // [{ type: "send_message", template: "...", delay: 0 }]
  
  // Stats
  executionCount Int   @default(0)
  lastExecutedAt DateTime?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, isActive])
  @@map("automations")
}

// ============================================================
// OUTBOX PATTERN (Reliable async processing)
// ============================================================

model OutboxEvent {
  id          String   @id @default(cuid())
  workspaceId String
  
  eventType   String   // order.created, message.send, order.reminder
  aggregateId String   // ID of the entity (orderId, messageId, etc.)
  payload     Json
  
  status      String   @default("pending") // pending, processing, completed, failed
  attempts    Int      @default(0)
  maxAttempts Int      @default(3)
  lastError   String?
  
  processedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, status, createdAt])
  @@index([eventType, status])
  @@map("outbox_events")
}

// ============================================================
// WEBHOOK IDEMPOTENCY
// ============================================================

model WebhookEvent {
  id            String   @id @default(cuid())
  source        String   // shopify, meta
  externalId    String   @unique // Shopify webhook ID or Meta message ID
  eventType     String   // orders/create, messages
  payload       Json
  processedAt   DateTime @default(now())
  createdAt     DateTime @default(now())

  @@index([source, externalId])
  @@map("webhook_events")
}

// ============================================================
// AUDIT LOG
// ============================================================

model AuditLog {
  id          String   @id @default(cuid())
  workspaceId String
  userId      String?
  action      String   // user.login, order.confirmed, message.sent
  entityType  String?  // order, contact, message
  entityId    String?
  metadata    Json?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([workspaceId, createdAt])
  @@index([userId])
  @@map("audit_logs")
}
