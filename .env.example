# =================================================================
# WhatsApp CRM POC - Environment Variables Example
# =================================================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env file to version control!
# =================================================================

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/whatsapp_crm"

# JWT Secret
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"

# WhatsApp Configuration (Optional - Only for demo purposes)
# For production, each workspace should configure these in the UI
# WHATSAPP_PHONE_NUMBER_ID=
# WHATSAPP_BUSINESS_ACCOUNT_ID=
# WHATSAPP_ACCESS_TOKEN=
WHATSAPP_WEBHOOK_VERIFY_TOKEN="your-webhook-verify-token-here"

# Shopify Configuration
# SHOPIFY_CLIENT_ID=
# SHOPIFY_CLIENT_SECRET=
# SHOPIFY_SCOPES=read_orders,write_orders,read_customers,write_customers

# Frontend URL (for OAuth callbacks)
FRONTEND_URL="http://localhost:3004"

# API URL
NEXT_PUBLIC_API_URL="http://localhost:3000"

# =================================================================
# SECURITY BEST PRACTICES:
# =================================================================
# 1. Add .env to .gitignore (already done)
# 2. Never hardcode credentials in source code
# 3. Use different credentials for dev/staging/prod
# 4. Rotate secrets regularly
# 5. Use a secrets manager in production (AWS Secrets Manager, Azure Key Vault, etc.)
# 6. Each workspace/tenant should have their own WhatsApp credentials
# =================================================================

# =================================================================
# MULTI-TENANCY:
# =================================================================
# This CRM is designed for multi-tenancy where:
# - Each workspace creates their own Meta App
# - Each workspace generates their own System User tokens  
# - Credentials are stored per-workspace in the database
# - Environment variables are only for system-wide settings
# =================================================================
